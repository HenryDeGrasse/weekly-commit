e, profile.overallAchievementRate(),\n\t\t\t\ttoStringKeys(profile.chessPieceAchievementRates()), profile.carryForwardProbability(),\n\t\t\t\tprofile.weeksOfData(), toStringKeys(profile.avgEstimateByPiece()),\n\t\t\t\tprofile.confidenceTier().name());\n\t}\n\n\t/** Sentinel response when data is insufficient or an error occurs. */\n\tpublic static CalibrationProfileResponse unavailable() {\n\t\treturn new CalibrationProfileResponse(false, 0.0, Map.of(), 0.0, 0, Map.of(),\n\t\t\t\tCalibrationConfidenceTier.INSUFFICIENT.name());\n\t}\n\n\tprivate static Map<String, Double> toStringKeys(Map<ChessPiece, Double> pieceMap) {\n\t\tif (pieceMap == null || pieceMap.isEmpty()) {\n\t\t\treturn Map.of();\n\t\t}\n\t\treturn pieceMap.entrySet().stream()\n\t\t\t\t.collect(Collectors.toMap(e -> e.getKey().name(), Map.Entry::getValue));\n\t}\n}\n"}}],"api":"anthropic-messages","provider":"anthropic","model":"claude-sonnet-4-6","usage":{"input":1,"output":834,"cacheRead":353278,"cacheWrite":2948,"totalTokens":357061,"cost":{"input":0.000003,"output":0.01251,"cacheRead":0.10598339999999999,"cacheWrite":0.011055,"total":0.12955139999999998}},"stopReason":"toolUse","timestamp":1774815468701,"responseId":"msg_01JjNbMwNdHinsbtsGFcPqTV"}}
